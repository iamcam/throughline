# Database — local dev only (Docker uses DB_* vars from project root .env)
# Make sure the DB_USER and DB_PASSWORD match those in DATABASE_URLs.
# They are used in different places/purposes
DB_USER=postgres
DB_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://postgres:changeme@localhost:5432/podcast_engine

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# LLM — any OpenAI-compatible endpoint
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL_NAME=llama3.1:8b

# Embeddings — defaults to LLM endpoint if not set
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_API_KEY=ollama
EMBEDDING_MODEL_NAME=nomic-embed-text
EMBEDDING_DIMENSIONS=768

# Transcription
# local | remote
TRANSCRIPTION_BACKEND=local

# only used for remote only
TRANSCRIPTION_SERVICE_URL=http://localhost:8001

# faster_whisper | mlx_whisper
WHISPER_BACKEND=faster_whisper

# model size or HF repo e.g. mlx-community/whisper-medium-mlx
WHISPER_MODEL=medium

# Diarization — off by default, computationally intensive
# Requires Hugging Face token and model access — see backend/README.md
# e.g. pyannote/speaker-diarization-3.1
DIARIZATION_MODEL=
# hf_...
HUGGINGFACE_TOKEN=

# Speaker inference
SPEAKER_INFERENCE_WINDOW_MS=900000

# Observability — disabled by default, see backend/README.md
TRACING_ENABLED=false
OTEL_ENDPOINT=http://localhost:6006/v1/traces
OTEL_API_KEY=
OTEL_PROJECT_NAME=podcast-engine

# Demo auth — disabled by default
# If enabled, DEMO_USERNAME and DEMO_PASSWORD must be changed from defaults
DEMO_AUTH_ENABLED=false
DEMO_USERNAME=demo
DEMO_PASSWORD=changeme