DB_USER=username
DB_PASSWORD=pass
DATABASE_URL=postgresql+asyncpg://username:pass@localhost:5432/podcast_engine

# List any domains CORS needs to allow.
CORS_ORIGINS=http://localhost:3000

HUGGINGFACE_TOKEN=abc


# LLM — any OpenAI-compatible endpoint
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL_NAME=Qwen/Qwen3.6-35B-A3B

# Embedding model - any OpenAI-compatible endpoint
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_API_KEY=ollama
EMBEDDING_MODEL_NAME=google-bert/bert-base-uncased
EMBEDDING_DIMENSIONS=768


SPEAKER_INFERENCE_WINDOW_MS=900000


# Transcription
TRANSCRIPTION_BACKEND=local
TRANSCRIPTION_SERVICE_URL=http://localhost:8001
WHISPER_BACKEND=faster_whisper # faster_whisper (default) | mlx_whisper
WHISPER_MODEL_SIZE=medium


# Diarization

# Diarization is computationally heavy - off by default: false (default) | true
# See README about diarization. empty to skip (default) | pyannote/speaker-diarization-community-1
DIARIZATION_MODEL=


# Observability

TRACING_ENABLED=false #default false
OTEL_ENDPOINT=http://localhost:4317
OTEL_API_KEY=<your-api-key>
OTEL_PROJECT_NAME=podcast-engine